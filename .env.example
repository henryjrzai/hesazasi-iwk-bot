# GitHub Configuration
# GITHUB_PAT didapat dari GitHub Developer Settings (Personal Access Token)
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx
# GITHUB_USERNAME adalah nama pengguna GitHub Anda (opsional)
GITHUB_USERNAME=username_anda

# OpenRouter Configuration
# OPENROUTER_API_KEY didapat dari OpenRouter dashboard
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
# Model default: openrouter/free
OPENROUTER_MODEL=openrouter/free

# Telegram Configuration
# TELEGRAM_BOT_TOKEN didapat dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCDefghIJKLmnopqrstuvWXYZ
# TELEGRAM_CHAT_ID didapat dari @userinfobot di Telegram
TELEGRAM_CHAT_ID=987654321

# Catatan: Jangan pernah membagikan file .env asli Anda atau mengunggahnya ke repositori publik!
